{
  "name": "aria-knowledge",
  "version": "2.13.7",
  "description": "ARIA — Applied Reasoning and Insight Architecture. Persistent human-governed knowledge for Claude Code via a five-phase lifecycle: capture → govern → promote → apply → refresh. Stages session insights/decisions/feedback into review backlogs, promotes approved items to a tag-indexed markdown base, and applies them via /context, /rules, /codemap, /stitch, /distill, /retrospect (release retrospectives with per-fix validation), and Rule 22 change-decision hooks on every Edit/Write. Ships 34 working rules + a 7-step framework, audit cadences, ideas-lifecycle routing, drift detection, an optional shared-knowledge tier for team promotions, and structural-signal surfacing on critical paths. IMPORTANT: All skills except /setup require ~/.claude/aria-knowledge.local.md to exist. If missing when any skill is invoked, stop and tell the user to run /setup.",
  "author": {
    "name": "Mike Prasad"
  },
  "homepage": "https://github.com/mikeprasad/aria-knowledge",
  "repository": "https://github.com/mikeprasad/aria-knowledge",
  "license": "CC-BY-NC-SA-4.0",
  "keywords": [
    "knowledge-management",
    "knowledge-capture",
    "decision-framework",
    "code-review",
    "session-knowledge",
    "audit",
    "tag-index",
    "context-retrieval",
    "hooks",
    "enforcement"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/session-start-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/pre-edit-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/pre-explore-codemap-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/post-edit-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/pre-compact-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/post-compact-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/task-context-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
